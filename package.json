{
  "private": true,
  "scripts": {
    "playwright:install": "cross-env PLAYWRIGHT_CHROMIUM_DOWNLOAD_HOST=https://cdn.npmmirror.com/binaries/chrome-for-testing playwright install",
    "postinstall": "patch-package && yarn playwright:install chromium-headless-shell",
    "build": "node build.js",
    "predebug": "yarn playwright:install chromium",
    "debug": "cross-env PWDEBUG=console node build.js",
    "start": "http-server dist -c-1 -a localhost -p 6478 -o"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.61.0",
    "readdirp": "^5.0.0",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
